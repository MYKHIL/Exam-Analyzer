{
  "entities": {
    "School": {
      "title": "School",
      "description": "Represents a school entity.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the school." },
        "adminUid": { "type": "string", "description": "The UID of the school administrator." },
        "authorizedUids": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs authorized to access this school." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "adminUid"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "schoolId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "assignedSubjects": { "type": "array", "items": { "type": "string" }, "description": "List of subject IDs this teacher is allowed to edit." }
      },
      "required": ["uid", "email", "schoolId", "role"]
    },
    "TeacherCode": {
      "title": "TeacherCode",
      "description": "A special access code generated by an admin for a teacher.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "schoolId": { "type": "string" },
        "assignedSubjects": { "type": "array", "items": { "type": "string" } },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "schoolId", "assignedSubjects", "isUsed"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Represents an exam session (e.g., Term 1 2024).",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the exam." },
        "schoolId": { "type": "string", "description": "The ID of the school this exam belongs to." },
        "createdAt": { "type": "string", "format": "date-time" },
        "subjects": { "type": "array", "items": { "type": "object" } },
        "gradeScales": { "type": "array", "items": { "type": "object" } },
        "subjRanges": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["name", "schoolId"]
    },
    "StudentBucket": {
      "title": "StudentBucket",
      "description": "A bucket containing all students for a specific exam to minimize reads/writes.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "schoolId": { "type": "string" },
        "students": { "type": "array", "items": { "$ref": "Student" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["examId", "schoolId", "students"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student and their scores.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sex": { "type": "string", "enum": ["M", "F"] },
        "scores": { "type": "object" }
      },
      "required": ["id", "name", "sex"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users."
    },
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Collection of schools."
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Collection of exams."
    },
    "/studentBuckets/{bucketId}": {
      "schema": "StudentBucket",
      "description": "Collection of student buckets (one per exam)."
    }
  }
}
