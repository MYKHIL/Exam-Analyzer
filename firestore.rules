rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSchoolAdmin(schoolId) {
      return isAuthenticated() && get(/databases/$(database)/documents/schools/$(schoolId)).data.adminUid == request.auth.uid;
    }

    function isExamOwner(examId) {
      let exam = get(/databases/$(database)/documents/exams/$(examId)).data;
      return isSchoolAdmin(exam.schoolId);
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.adminUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.adminUid == request.auth.uid;
      allow delete: if false; // Schools shouldn't be easily deleted
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isAuthenticated() && isSchoolAdmin(resource.data.schoolId);
      allow delete: if isAuthenticated() && isSchoolAdmin(resource.data.schoolId);
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isAuthenticated() && isSchoolAdmin(resource.data.schoolId);
      allow delete: if isAuthenticated() && isSchoolAdmin(resource.data.schoolId);
    }
  }
}
