rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAuthorizedForSchool(schoolData) {
      return isAuthenticated() && (
        schoolData.get('adminUid', '') == request.auth.uid || 
        (schoolData.get('authorizedUids', []) is list && request.auth.uid in schoolData.authorizedUids)
      );
    }

    function isSchoolAdmin(schoolId) {
      return isAuthenticated() && schoolId != null && get(/databases/$(database)/documents/schools/$(schoolId)).data.get('adminUid', '') == request.auth.uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || (resource.data.get('schoolId', null) != null && isSchoolAdmin(resource.data.schoolId)));
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || (resource.data.get('schoolId', null) != null && isSchoolAdmin(resource.data.schoolId)));
    }

    // Schools
    match /schools/{schoolId} {
      // Use get() with default values for better query support
      allow read: if isAuthenticated() && resource.data.get('adminUid', '') == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.get('authorizedUids', []) is list && request.auth.uid in resource.data.authorizedUids;
      
      allow create: if isAuthenticated() && request.resource.data.get('adminUid', '') == request.auth.uid;
      allow update: if isAuthenticated() && isSchoolAdmin(schoolId);
      allow delete: if false;
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.get('schoolId', ''))).data);
      allow create: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(request.resource.data.get('schoolId', ''))).data);
      allow update: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.get('schoolId', ''))).data);
      allow delete: if isAuthenticated() && isSchoolAdmin(resource.data.get('schoolId', ''));
    }

    // Student Buckets
    match /studentBuckets/{bucketId} {
      allow read: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.get('schoolId', ''))).data);
      allow create: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(request.resource.data.get('schoolId', ''))).data);
      allow update: if isAuthenticated() && isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.get('schoolId', ''))).data);
      allow delete: if isAuthenticated() && isSchoolAdmin(resource.data.get('schoolId', ''));
    }
  }
}
