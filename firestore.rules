rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - schoolId: string (optional)
    //   - lastLogin: string (optional, ISO 8601)
    //
    // Collection: schools
    // Document ID: {schoolId} (Auto-generated)
    // Fields:
    //   - name: string (required)
    //   - adminUid: string (required)
    //   - authorizedUids: list of strings (optional)
    //   - createdAt: string (required, ISO 8601)
    //
    // Collection: exams
    // Document ID: {examId} (Auto-generated)
    // Fields:
    //   - name: string (required)
    //   - schoolId: string (required)
    //   - date: string (required, ISO 8601)
    //
    // Collection: studentBuckets
    // Document ID: {bucketId} (Auto-generated)
    // Fields:
    //   - examId: string (required)
    //   - schoolId: string (required)
    //   - students: list of objects (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "mykhilcreations6@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isSchoolAdmin(schoolId) {
      return isAuthenticated() && 
             schoolId != null && 
             schoolId != "" &&
             exists(/databases/$(database)/documents/schools/$(schoolId)) &&
             (
               get(/databases/$(database)/documents/schools/$(schoolId)).data.adminUid == request.auth.uid || 
               isAdmin()
             );
    }

    function isAuthorizedForSchool(schoolData) {
      return isAuthenticated() && (
        schoolData.get('adminUid', '') == request.auth.uid || 
        (schoolData.get('authorizedUids', []) is list && request.auth.uid in schoolData.get('authorizedUids', [])) ||
        isAdmin()
      );
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        (
          resource.data.get('schoolId', '') != '' && 
          isSchoolAdmin(resource.data.schoolId)
        )
      );
      allow delete: if isAdmin();
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.get('adminUid', '') == request.auth.uid;
      allow update: if isAuthenticated() && (
        isSchoolAdmin(schoolId) || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorizedUids']) &&
          request.auth.uid in request.resource.data.authorizedUids
        )
      );
      allow delete: if isAdmin();
    }

    // Teacher Codes
    match /teacherCodes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSchoolAdmin(request.resource.data.get('schoolId', ''));
      allow update: if isAuthenticated() && (
        isSchoolAdmin(resource.data.get('schoolId', '')) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy', 'usedAt']))
      );
      allow delete: if isAuthenticated() && isSchoolAdmin(resource.data.get('schoolId', ''));
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated() && (
        resource == null || (
          resource.data.get('schoolId', null) != null &&
          exists(/databases/$(database)/documents/schools/$(resource.data.schoolId)) &&
          isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data)
        )
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.get('schoolId', null) != null &&
        exists(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)) &&
        isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data);
      
      allow update: if isAuthenticated() && 
        resource.data.get('schoolId', null) != null &&
        exists(/databases/$(database)/documents/schools/$(resource.data.schoolId)) &&
        isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data);
      
      allow delete: if isAuthenticated() && 
        resource.data.get('schoolId', null) != null &&
        isSchoolAdmin(resource.data.schoolId);
    }

    // Student Buckets
    match /studentBuckets/{bucketId} {
      allow read: if isAuthenticated() && (
        resource == null || (
          resource.data.get('schoolId', null) != null &&
          exists(/databases/$(database)/documents/schools/$(resource.data.schoolId)) &&
          isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data)
        )
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.get('schoolId', null) != null &&
        exists(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)) &&
        isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data);
      
      allow update: if isAuthenticated() && 
        resource.data.get('schoolId', null) != null &&
        exists(/databases/$(database)/documents/schools/$(resource.data.schoolId)) &&
        isAuthorizedForSchool(get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data);
      
      allow delete: if isAuthenticated() && 
        resource.data.get('schoolId', null) != null &&
        isSchoolAdmin(resource.data.schoolId);
    }
  }
}
